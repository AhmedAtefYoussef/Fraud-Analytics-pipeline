# Python local caches
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# Byte-compiled / optimized / DLL files
*.pyc
*.pyo
*.pyd

# Local environment configuration
.env
.env.*

# Datasets (large CSV files) - Anchored to root
/data/

# Serialization binary model weights - Anchored to root
/models/

# Logging directories - Anchored to root
/logs/
*.log

# Figure reports and generated outputs - Anchored to root
# /reports/
reports/**/*.html
.pytest_cache/
.mypy_cache/
